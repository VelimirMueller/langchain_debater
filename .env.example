# Anthropic (the actual model calls)
ANTHROPIC_API_KEY=

# LangSmith — auto-attached by LangChain when these are set
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=langchain-learning-debate

# Langfuse — read by LangfuseHandler() constructor
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Anthropic (the actual model calls)
ANTHROPIC_API_KEY=

# LangSmith — auto-attached by LangChain when these are set
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=langchain-learning-debate
# EU accounts MUST set this; US accounts can omit it (defaults to api.smith.langchain.com).
# Wrong region = 403 Forbidden on /runs/multipart uploads.
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com

# Langfuse — read by LangfuseHandler() constructor
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Tavily — web search + page extract. Sign up at https://tavily.com.
# Free tier: 1,000 credits/month. One credit per basic search or extract.
TAVILY_API_KEY=
